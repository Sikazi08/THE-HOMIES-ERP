# Copy these values into Hostinger environment variables.
# Replace placeholders with the real values from Supabase.
# Do not commit your real password.

NODE_ENV=production
NODE_VERSION=24.17.0
BASE_PATH=/
SESSION_SECRET=replace-with-a-long-random-secret
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Leave PORT empty unless Hostinger gives you a specific port.
# Do not set API_PROXY_TARGET in production.
# Do not set SESSION_STORE=postgres unless you deliberately want database-backed sessions.
